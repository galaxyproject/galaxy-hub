{
  "name": "galaxy-hub",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "preprocess": "node src/build/preprocess.mjs",
    "preprocess:verbose": "node src/build/preprocess.mjs --verbose",
    "search-index": "node src/build/generate-search-index.mjs",
    "generate-redirects": "node src/build/generate-redirects.mjs",
    "generate-404-lookup": "node src/build/generate-404-lookup.mjs",
    "release-guardians:sync-event": "node src/build/release-guardians-sync-event.mjs",
    "dev": "npm run preprocess && npm run generate-redirects && npm run search-index && npm run generate-404-lookup && (trap 'kill 0' EXIT; node src/build/preprocess.mjs --watch-only & ASTRO_DEV_BACKGROUND=0 astro dev)",
    "build": "npm run preprocess && npm run generate-redirects && npm run search-index && npm run generate-404-lookup && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "links:internal": "node src/build/check-links.mjs",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write 'src/**/*.{js,mjs,ts,vue,astro,css}'",
    "format:check": "prettier --check 'src/**/*.{js,mjs,ts,vue,astro,css}'",
    "normalize": "node src/build/normalize-content.mjs",
    "content:lint": "node src/build/normalize-content.mjs --all --check && node src/build/check-dir-names.mjs && node src/build/check-filename-case.mjs"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "^7.2.1",
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/rss": "^4.0.17",
    "@astrojs/sitemap": "^3.7.1",
    "@astrojs/vue": "^7.0.0",
    "@citation-js/core": "^0.8.2",
    "@citation-js/plugin-bibtex": "^0.8.2",
    "@fontsource/atkinson-hyperlegible": "^5.2.8",
    "@galaxyproject/brand-tokens": "^0.1.0",
    "@lucide/vue": "^1.24.0",
    "@nanostores/vue": "^1.0.1",
    "@sindresorhus/slugify": "^3.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.2",
    "@vueuse/core": "^14.1.0",
    "astro": "^7.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "glob": "^13.0.0",
    "gray-matter": "^4.0.3",
    "lucide-static": "^1.24.0",
    "marked": "^18.0.6",
    "nanostores": "^1.1.0",
    "ol": "^10.7.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "reka-ui": "^2.6.1",
    "remark-frontmatter": "^5.0.0",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "remark-toc": "^9.0.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.3.2",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "vega": "^6.2.0",
    "vega-embed": "^7.1.0",
    "vega-lite": "^6.4.1",
    "vue": "^3.5.25",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.57.0",
    "eslint": "^10.7.0",
    "eslint-plugin-astro": "^2.1.1",
    "eslint-plugin-vue": "^10.9.2",
    "fast-xml-parser": "^5.4.1",
    "globals": "^17.7.0",
    "linkinator": "^7.6.1",
    "prettier": "^3.3.0",
    "prettier-plugin-astro": "^0.14.0",
    "tw-animate-css": "^1.4.0",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10",
    "vue-eslint-parser": "^10.4.1"
  },
  "packageManager": "pnpm@10.26.1+sha512.664074abc367d2c9324fdc18037097ce0a8f126034160f709928e9e9f95d98714347044e5c3164d65bd5da6c59c6be362b107546292a8eecb7999196e5ce58fa"
}
