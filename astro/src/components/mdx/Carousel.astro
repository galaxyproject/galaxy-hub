---
import CarouselVue from '../embed/Carousel.vue';

interface Props {
  images?: any[];
  src?: string;
  link?: string;
  autoplay?: boolean;
  interval?: number;
}

const props = Astro.props;
---

<CarouselVue
  client:visible
  autoplay={props.autoplay ?? true}
  interval={props.interval ?? 5000}
  images={props.images ?? [
    {
      src: '/images/NAR-2026-Update.png',
      alt: 'Galaxy 2026 update published in Nucleic Acids Research',
      link: 'https://academic.oup.com/nar/advance-article/doi/10.1093/nar/gkag469/8704296',
    },
    {
      src: '/images/events/Carousel_galaxy_master_FR_2026.png',
      alt: 'Galaxy Beyond Basics - Announcement',
      link: 'https://galaxyproject.org/events/2026-10-12-Advanced-Galaxy-Training/',
    },
    {
      src: '/images/usegalaxy-welcome/jxtx_carousel.svg',
      alt: 'Donate to the James P. Taylor Foundation for Open Science',
      link: 'https://jxtxfoundation.org',
    },
    {
      src: '/images/usegalaxy-welcome/theguy.svg',
      alt: 'Use collections!',
      link: 'https://galaxyproject.org/news/2025-10-21-whycollections/',
    },
    {
      src: '/images/usegalaxy-welcome/window_manager.svg',
      alt: 'Use collections!',
      link: 'https://galaxyproject.org/news/2025-10-28-window-manager/',
    },
    {
      src: '/images/usegalaxy-welcome/gtn.svg',
      alt: 'Try GTN',
      link: 'https://training.galaxyproject.org/',
    },
    {
      src: '/images/usegalaxy-welcome/dotstar.svg',
      alt: 'Usegalaxy.*',
      link: 'https://galaxyproject.org/usegalaxy/',
    },
  ]}
/>
