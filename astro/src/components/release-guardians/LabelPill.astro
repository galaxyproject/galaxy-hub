---
interface Props {
  label: string;
  kind?: 'in-progress' | 'complete';
}
const { label, kind = 'in-progress' } = Astro.props;

const tone =
  kind === 'complete'
    ? 'bg-emerald-50 text-emerald-700 border-emerald-200'
    : 'bg-amber-50 text-amber-700 border-amber-200';
---

<span class={`inline-flex items-center px-2 py-0.5 text-xs rounded-full border font-mono align-middle ${tone}`}
  >{label}</span
>
