---
import type { SnapshotKind } from './data';
import { TONES } from './tones';

interface Props {
  label: string;
  kind?: SnapshotKind;
}
const { label, kind = 'inProgress' } = Astro.props;
---

<span
  class={`inline-flex items-center px-2 py-0.5 text-xs rounded-full border font-mono align-middle ${TONES[kind].pill}`}
  >{label}</span
>
