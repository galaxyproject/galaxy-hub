---
import type { SnapshotKind } from './data';
import { TONES } from './tones';

interface Props {
  label: string;
  kind: SnapshotKind;
}
const { label, kind } = Astro.props;
---

<span
  class={`inline-flex items-center px-3 py-0.5 text-xs font-medium rounded-full border align-middle ${TONES[kind].pill}`}
  >{label}</span
>
