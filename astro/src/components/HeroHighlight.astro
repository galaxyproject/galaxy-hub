---
import { normalizeSlug } from '../build/slug-utils.mjs';

// Edit these to change the homepage hero highlight.
// Set image to "" to show the Galaxy logo instead.
const rawImage = '/images/events/gcc2026/gcc2026-carousel.png';
const link = '/events/gcc2026/';
const alt = 'Galaxy Community Conference 2026';

// Normalize directory segments to match preprocessing output.
function normalizeImagePath(src: string) {
  if (!src) return src;
  const lastSlash = src.lastIndexOf('/');
  if (lastSlash < 0) return src;
  const dir = src.slice(0, lastSlash);
  const file = src.slice(lastSlash);
  return normalizeSlug(dir) + file;
}
const image = normalizeImagePath(rawImage);
---

{
  image ? (
    <div class="hero-highlight-container">
      <img src="/images/galaxy_logo_white.svg" alt="Galaxy" class="hero-logo" />
      <a href={link} class="hero-highlight-link">
        <img src={image} alt={alt} class="hero-highlight-img" />
      </a>
    </div>
  ) : (
    <img src="/images/galaxy_logo_white.svg" alt="Galaxy" class="hero-logo" />
  )
}

<style is:global>
  .hero-highlight-container {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
  }

  .hero-logo {
    width: 360px;
    max-width: 100%;
    height: auto;
    filter: drop-shadow(0 20px 40px rgba(0, 0, 0, 0.3));
    animation: hero-fade-out 0.6s ease 1s forwards;
  }

  .hero-highlight-link {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    display: block;
    width: 520px;
    max-width: 100%;
    border-radius: 12px;
    overflow: hidden;
    opacity: 0;
    border: 1px solid rgba(255, 255, 255, 0.15);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
    animation: hero-fade-in 0.6s ease 1s forwards;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      border-color 0.2s ease;
  }

  .hero-highlight-link:hover {
    transform: translate(-50%, calc(-50% - 2px));
    border-color: rgba(255, 255, 255, 0.3);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4);
  }

  .hero-highlight-img {
    display: block;
    width: 100%;
    max-width: 520px;
    height: auto;
  }

  @keyframes hero-fade-out {
    to {
      opacity: 0;
      pointer-events: none;
    }
  }

  @keyframes hero-fade-in {
    to {
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-logo {
      animation: none;
      opacity: 0 !important;
    }

    .hero-highlight-link {
      opacity: 1 !important;
      animation: none;
      position: relative;
    }
  }

  @media (max-width: 900px) {
    .hero-highlight-link {
      width: 360px;
    }

    .hero-logo {
      width: 240px;
    }
  }
</style>
