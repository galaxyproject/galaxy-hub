---
// Edit these to change the homepage hero highlight.
// Set image to "" to show the Galaxy logo instead.
const image = "/images/events/gcc2026/gcc2026-carousel.png";
const link = "/events/gcc2026/";
const alt = "Galaxy Community Conference 2026";
---

{
  image ? (
    <a href={link} class="hero-highlight-link">
      <img src={image} alt={alt} class="hero-highlight-img" />
    </a>
  ) : (
    <img src="/images/galaxy_logo_white.svg" alt="Galaxy" class="hero-logo-fallback" />
  )
}

<style>
  .hero-highlight-link {
    display: block;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .hero-highlight-link:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4);
  }

  .hero-highlight-img {
    display: block;
    width: 100%;
    max-width: 520px;
    height: auto;
  }

  .hero-logo-fallback {
    max-width: 360px;
    height: auto;
    filter: drop-shadow(0 20px 40px rgba(0, 0, 0, 0.3));
  }

  @media (max-width: 900px) {
    .hero-highlight-img {
      max-width: 360px;
    }

    .hero-logo-fallback {
      max-width: 240px;
    }
  }
</style>
