---
/**
 * UseGalaxy.org Welcome Page
 *
 * Embedded in Galaxy instances as the welcome screen users see when loading usegalaxy.org.
 * Self-contained page (no site header/footer) displayed within an iframe.
 */
import '../../styles/global.css';
import Icon from '../../components/mdx/Icon.astro';

const carouselSlides = [
  {
    href: 'https://jxtxfoundation.org',
    img: '/images/usegalaxy-welcome/jxtx_carousel.svg',
    alt: 'Donate to the James P. Taylor Foundation for Open Science',
  },
  {
    href: 'https://galaxyproject.org/news/2025-10-21-whycollections/',
    img: '/images/usegalaxy-welcome/theguy.svg',
    alt: 'Use collections!',
  },
  {
    href: 'https://galaxyproject.org/news/2025-10-28-window-manager/',
    img: '/images/usegalaxy-welcome/window_manager.svg',
    alt: 'Window Manager',
  },
  { href: 'https://training.galaxyproject.org/', img: '/images/usegalaxy-welcome/gtn.svg', alt: 'Try GTN' },
  { href: 'https://galaxyproject.org/usegalaxy/', img: '/images/usegalaxy-welcome/dotstar.svg', alt: 'Usegalaxy.*' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Welcome to Galaxy</title>
  </head>
  <body class="bg-white text-gray-700 leading-relaxed max-w-[900px] mx-auto p-5">
    <!-- Hero Banner -->
    <section class="welcome-hero">
      <div class="relative z-1">
        <p class="text-base leading-relaxed m-0">
        <strong class="text-lg">Galaxy</strong> is an open source, web-based platform for data intensive biomedical research.
        If you are new to Galaxy
        <a
          href="https://usegalaxy.org/galaxy101"
          class="text-galaxy-gold hover:text-accent-hover underline underline-offset-2">start here</a
        >
        or consult our help resources. You can install your own Galaxy by following the
        <a href="http://getgalaxy.org" class="text-galaxy-gold hover:text-accent-hover underline underline-offset-2"
          >tutorial</a
        >
        and choose from thousands of tools from the
        <a
          href="https://galaxyproject.org/admin/tools/add-tool-from-toolshed-tutorial"
          class="text-galaxy-gold hover:text-accent-hover underline underline-offset-2">Tool Shed</a
        >.
      </p>
      </div>
    </section>

    <!-- Media Row: Carousel + YouTube -->
    <section class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <!-- Carousel -->
      <div>
        <div class="rounded-lg overflow-hidden shadow-md bg-gray-200" id="welcome-carousel">
          <div class="relative w-full" style="aspect-ratio: 13/9;">
            {
              carouselSlides.map((slide, index) => (
                <div
                  class={`carousel-slide absolute inset-0 transition-opacity duration-500 ${index === 0 ? 'opacity-100' : 'opacity-0 pointer-events-none'}`}
                  data-index={index}
                >
                  <a href={slide.href} target="_blank" class="block w-full h-full">
                    <img src={slide.img} alt={slide.alt} class="w-full h-full object-cover" />
                  </a>
                </div>
              ))
            }
            <div class="absolute inset-y-0 left-0 flex items-center pl-2">
              <button
                id="prev-btn"
                aria-label="Previous slide"
                class="bg-black/40 hover:bg-black/60 text-white rounded-full w-8 h-8 flex items-center justify-center text-lg transition-colors cursor-pointer border-0"
                >&#8249;</button
              >
            </div>
            <div class="absolute inset-y-0 right-0 flex items-center pr-2">
              <button
                id="next-btn"
                aria-label="Next slide"
                class="bg-black/40 hover:bg-black/60 text-white rounded-full w-8 h-8 flex items-center justify-center text-lg transition-colors cursor-pointer border-0"
                >&#8250;</button
              >
            </div>
          </div>
          <div class="flex justify-center gap-2 py-2 bg-white">
            {
              carouselSlides.map((_, index) => (
                <button
                  class={`carousel-indicator w-2.5 h-2.5 rounded-full transition-colors cursor-pointer border-0 ${index === 0 ? 'bg-galaxy-primary' : 'bg-gray-300 hover:bg-gray-400'}`}
                  data-index={index}
                  aria-label={`Go to slide ${index + 1}`}
                />
              ))
            }
          </div>
        </div>
      </div>

      <!-- YouTube -->
      <div>
        <div class="rounded-lg overflow-hidden shadow-md">
          <iframe
            src="https://www.youtube-nocookie.com/embed/k6fTVIR4GME?mute=1&cc_load_policy=1&autoplay=0&loop=0&playlist=k6fTVIR4GME"
            title="YouTube video player"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            class="w-full border-0 block"
            style="aspect-ratio: 400/277;"></iframe>
        </div>
      </div>
    </section>

    <!-- JXTX Foundation CTA -->
    <section class="bg-galaxy-dark rounded-lg p-6 mb-8 text-white flex flex-col sm:flex-row items-start sm:items-center gap-4">
      <div class="flex-1">
        <p class="font-bold text-lg mb-1">James P. Taylor Foundation for Open Science</p>
        <p class="text-white/70 text-sm m-0 italic">"The most important job of senior faculty is to mentor junior faculty and students."</p>
      </div>
      <a
        href="https://jxtxfoundation.org/"
        target="_blank"
        class="inline-flex items-center gap-2 bg-white hover:bg-galaxy-gold text-galaxy-dark font-semibold px-5 py-2.5 rounded-md transition-colors text-sm uppercase tracking-wide no-underline shrink-0"
      >
        <Icon name="heart" size={16} />
        Donate
      </a>
    </section>

    <!-- Social Media -->
    <section class="text-center mb-8">
      <p class="font-semibold text-galaxy-dark mb-3">Follow us on social media</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a
          href="https://mstdn.science/@galaxyproject"
          target="_blank"
          class="inline-flex items-center gap-1.5 border border-galaxy-primary text-galaxy-primary hover:bg-galaxy-primary hover:text-white px-4 py-2 rounded-full transition-colors text-sm font-medium no-underline"
        >
          <Icon name="message-circle" size={16} />
          Mastodon
        </a>
        <a
          href="https://bsky.app/profile/galaxyproject.bsky.social"
          target="_blank"
          class="inline-flex items-center gap-1.5 border border-galaxy-primary text-galaxy-primary hover:bg-galaxy-primary hover:text-white px-4 py-2 rounded-full transition-colors text-sm font-medium no-underline"
        >
          <Icon name="cloud" size={16} />
          Bluesky
        </a>
        <a
          href="https://www.linkedin.com/company/101662592"
          target="_blank"
          class="inline-flex items-center gap-1.5 border border-galaxy-primary text-galaxy-primary hover:bg-galaxy-primary hover:text-white px-4 py-2 rounded-full transition-colors text-sm font-medium no-underline"
        >
          <Icon name="linkedin" size={16} />
          LinkedIn
        </a>
      </div>
    </section>

    <hr class="border-gray-200 my-8" />

    <!-- Institutions & Infrastructure -->
    <section class="grid grid-cols-1 md:grid-cols-[1fr_2fr] gap-8 mb-8">
      <div>
        <div class="flex items-center justify-center gap-6 mb-4" style="min-height: 80px;">
          <a href="http://www.psu.edu/" target="_blank">
            <img src="/images/usegalaxy-welcome/psu_logo.png" alt="Penn State University" class="max-h-16" />
          </a>
          <a href="http://www.bio.jhu.edu/" target="_blank">
            <img src="/images/usegalaxy-welcome/jhu_logo.png" alt="Johns Hopkins University" class="max-h-16" />
          </a>
        </div>
        <p class="text-sm text-gray-600 leading-relaxed">
          <a href="https://galaxyproject.org/galaxy-team/" class="text-galaxy-primary hover:underline">The Galaxy Team</a
          > is a part of
          <a href="http://www.bx.psu.edu/" class="text-galaxy-primary hover:underline"
            >the Center for Comparative Genomics and Bioinformatics</a
          > at <a href="http://www.psu.edu/" class="text-galaxy-primary hover:underline">Penn State</a> and the
          <a href="http://www.bio.jhu.edu/" class="text-galaxy-primary hover:underline">Department of Biology</a> at
          <a href="http://www.jhu.edu/" class="text-galaxy-primary hover:underline">Johns Hopkins University</a>.
        </p>
      </div>

      <div>
        <div class="flex items-center justify-center gap-6 mb-4" style="min-height: 80px;">
          <a href="https://www.tacc.utexas.edu/" target="_blank">
            <img src="/images/usegalaxy-welcome/tacc_logo.png" alt="Texas Advanced Computing Center" class="max-h-16" />
          </a>
          <a href="https://access-ci.org/" target="_blank">
            <img src="/images/usegalaxy-welcome/access_logo.png" alt="ACCESS" class="max-h-16" />
          </a>
          <a href="https://jetstream-cloud.org/" target="_blank">
            <img src="/images/usegalaxy-welcome/jetstream2_logo.png" alt="Jetstream2" class="max-h-16" />
          </a>
        </div>
        <p class="text-sm text-gray-600 leading-relaxed">
          This instance of Galaxy is utilizing infrastructure generously provided by the
          <a href="https://tacc.utexas.edu/" class="text-galaxy-primary hover:underline"
            >Texas Advanced Computing Center</a
          >. Additional resources are provided primarily on the
          <a href="https://jetstream-cloud.org/" class="text-galaxy-primary hover:underline">Jetstream2</a> cloud via
          <a href="https://access-ci.org/" class="text-galaxy-primary hover:underline">ACCESS</a>, and with support from
          the <a href="http://www.nsf.gov" class="text-galaxy-primary hover:underline">National Science Foundation</a>.
        </p>
      </div>
    </section>

    <!-- Funding & Legal -->
    <section class="mb-8 text-xs text-gray-500 leading-relaxed space-y-3 border-t border-gray-200 pt-4">
        <p>
          The development and maintenance of this site are supported by
          <a href="https://www.nih.gov/" class="text-galaxy-primary hover:underline">NIH</a>
          <a href="http://www.genome.gov" class="text-galaxy-primary hover:underline">NHGRI</a>
          award U24HG006620. Additional support is provided by
          <a href="https://www.nih.gov/" class="text-galaxy-primary hover:underline">NIH</a>
          awards U24HG010263, U24AI183870, U24CA284167, and OT2OD037936, as well as
          <a href="http://www.nsf.gov" class="text-galaxy-primary hover:underline">NSF</a> award 2419522.
        </p>
        <p>
          This site uses
          <a href="https://jetstream-cloud.org/" class="text-galaxy-primary hover:underline">Jetstream2</a> at the
          <a href="https://pti.iu.edu/" class="text-galaxy-primary hover:underline"
            >Indiana University Pervasive Technology Institute</a
          >,
          <a href="https://www.psc.edu/resources/bridges-2/" class="text-galaxy-primary hover:underline">Bridges-2</a> at
          the
          <a href="https://www.psc.edu/" class="text-galaxy-primary hover:underline">Pittsburgh Supercomputing Center</a>,
          <a
            href="https://www.arch.jhu.edu/about-arch/system-configuration/"
            class="text-galaxy-primary hover:underline">Rockfish</a
          > at
          <a href="https://www.arch.jhu.edu/" class="text-galaxy-primary hover:underline"
            >Johns Hopkins University Advanced Research Computing</a
          >,
          <a href="https://tacc.utexas.edu/systems/stampede3/" class="text-galaxy-primary hover:underline">Stampede3</a>
          and
          <a href="https://tacc.utexas.edu/systems/ranch/" class="text-galaxy-primary hover:underline">Ranch</a> at the
          <a href="https://tacc.utexas.edu/" class="text-galaxy-primary hover:underline"
            >Texas Advanced Computing Center</a
          >, and
          <a href="https://www.sdsc.edu/services/hpc/expanse/" class="text-galaxy-primary hover:underline">Expanse</a> at
          the
          <a href="https://www.sdsc.edu/" class="text-galaxy-primary hover:underline"
            >San Diego Supercomputer Center</a
          >, through allocation MCB140147 from the
          <a href="https://access-ci.org/" class="text-galaxy-primary hover:underline"
            >Advanced Cyberinfrastructure Coordination Ecosystem: Services &amp; Support (ACCESS)</a
          >
          program, which is supported by
          <a href="http://www.nsf.gov" class="text-galaxy-primary hover:underline">National Science Foundation</a>
          grants #2138259, #2138286, #2138307, #2137603, and #2138296.
        </p>
        <p>
          This is a free, public, internet accessible resource. Data transfer and data storage are not encrypted. If there
          are restrictions on the way your research data can be stored and used, please consult your local institutional
          review board or the project PI before uploading it to any public site, including this Galaxy server. If you have
          protected data, large data storage requirements, or short deadlines you are encouraged to set up your own
          <a href="http://getgalaxy.org" class="text-galaxy-primary hover:underline">local Galaxy instance</a> or run
          <a href="http://usegalaxy.org/cloud" class="text-galaxy-primary hover:underline">Galaxy on the cloud</a>.
        </p>
        <p>
          See the
          <a href="https://usegalaxy.org/static/terms.html" class="text-galaxy-primary hover:underline"
            >Terms of Service and Privacy Policy</a
          >
          for more information, including our cookie policy.
        </p>
    </section>

    <style>
      .welcome-hero {
        position: relative;
        padding: 2rem;
        background: linear-gradient(135deg, var(--color-galaxy-primary) 0%, var(--color-galaxy-dark) 100%);
        color: white;
        border-radius: 0.5rem;
        margin-bottom: 2rem;
        border-bottom: 4px solid var(--color-galaxy-gold);
      }

      .welcome-hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image:
          linear-gradient(to right, rgba(255, 255, 255, 0.03) 1px, transparent 1px),
          linear-gradient(to bottom, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
        background-size: 24px 24px;
        pointer-events: none;
        border-radius: inherit;
      }
    </style>

    <script>
      let welcomeCarouselInterval: ReturnType<typeof setInterval> | undefined;

      function initWelcomeCarousel() {
        if (welcomeCarouselInterval) {
          clearInterval(welcomeCarouselInterval);
          welcomeCarouselInterval = undefined;
        }

        const carousel = document.getElementById('welcome-carousel');
        if (!carousel) return;

        const slides = carousel.querySelectorAll('.carousel-slide') as NodeListOf<HTMLElement>;
        const indicators = document.querySelectorAll('.carousel-indicator') as NodeListOf<HTMLElement>;
        const prevBtn = document.getElementById('prev-btn');
        const nextBtn = document.getElementById('next-btn');

        let currentSlide = 0;

        function showSlide(index: number) {
          if (index >= slides.length) index = 0;
          if (index < 0) index = slides.length - 1;

          slides.forEach((slide) => {
            slide.classList.add('opacity-0', 'pointer-events-none');
            slide.classList.remove('opacity-100');
          });
          indicators.forEach((ind) => {
            ind.classList.remove('bg-galaxy-primary');
            ind.classList.add('bg-gray-300');
          });

          slides[index].classList.remove('opacity-0', 'pointer-events-none');
          slides[index].classList.add('opacity-100');
          indicators[index].classList.remove('bg-gray-300');
          indicators[index].classList.add('bg-galaxy-primary');
          currentSlide = index;
        }

        function nextSlide() {
          showSlide(currentSlide + 1);
        }

        function prevSlide() {
          showSlide(currentSlide - 1);
        }

        function startAutoPlay() {
          welcomeCarouselInterval = setInterval(nextSlide, 3000);
        }

        function stopAutoPlay() {
          if (welcomeCarouselInterval) {
            clearInterval(welcomeCarouselInterval);
            welcomeCarouselInterval = undefined;
          }
        }

        nextBtn?.addEventListener('click', () => {
          stopAutoPlay();
          nextSlide();
          startAutoPlay();
        });

        prevBtn?.addEventListener('click', () => {
          stopAutoPlay();
          prevSlide();
          startAutoPlay();
        });

        indicators.forEach((indicator, index) => {
          indicator.addEventListener('click', () => {
            stopAutoPlay();
            showSlide(index);
            startAutoPlay();
          });
        });

        carousel.addEventListener('mouseenter', stopAutoPlay);
        carousel.addEventListener('mouseleave', startAutoPlay);

        startAutoPlay();
      }

      // astro:page-load for ViewTransitions, DOMContentLoaded as fallback for standalone pages
      document.addEventListener('astro:page-load', initWelcomeCarousel);
      document.addEventListener('DOMContentLoaded', initWelcomeCarousel);

      document.addEventListener('astro:before-swap', () => {
        if (welcomeCarouselInterval) {
          clearInterval(welcomeCarouselInterval);
          welcomeCarouselInterval = undefined;
        }
      });
    </script>
  </body>
</html>
