---
import { getCollection } from 'astro:content';
import PlatformMap from './PlatformMap.vue';
import '../../../styles/global.css';
import { prepareMapPlatformData } from './mapDataUtils';

// Get all platforms
const platforms = await getCollection('platforms');

// Prepare map data using self-contained utility
const platformData = prepareMapPlatformData(platforms);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Galaxy Platform Map</title>
    <style>
      body {
        margin: 0;
        padding: 0;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
      }
      #map-container {
        width: 100%;
        height: 100vh;
      }
    </style>
  </head>
  <body>
    <div id="map-container">
      <PlatformMap client:only="vue" platforms={platformData} />
    </div>
  </body>
</html>
